# Core
AURORA_DATABASE_URL=postgresql+psycopg://aurora:aurora@localhost:5432/aurora
AURORA_REDIS_URL=redis://localhost:6379/0
AURORA_USE_INMEMORY_QUEUE=false
AURORA_BOOTSTRAP_TOKEN=aurora-bootstrap-token
AURORA_ADMIN_TOKEN=aurora-admin-token
AURORA_SUPERADMIN_USERNAME=superadmin
AURORA_SUPERADMIN_PASSWORD=superadmin
AURORA_PLUGINS_DIR=plugins
AURORA_BACKUP_DIR=backups
AURORA_BACKUP_MAX_STORAGE_GB=20
AURORA_BACKUP_RETENTION_DAILY=7
AURORA_BACKUP_RETENTION_WEEKLY=4
AURORA_BACKUP_RETENTION_MONTHLY=3
AURORA_BACKUP_OFFSITE_DIR=
AURORA_BACKUP_SCHEDULER_ENABLED=true
AURORA_BACKUP_SCHEDULE_CREATE_MINUTES=1440
AURORA_BACKUP_SCHEDULE_VALIDATE_MINUTES=1440
AURORA_BACKUP_SCHEDULE_PRUNE_MINUTES=1440
AURORA_BACKUP_SCHEDULE_RESTORE_DRILL_MINUTES=10080
AURORA_HEARTBEAT_TTL_SECONDS=60
AURORA_LEASE_TTL_SECONDS=90

# Agent
AURORA_AGENT_CORE_URL=http://127.0.0.1:8000
AURORA_AGENT_BOOTSTRAP_TOKEN=aurora-bootstrap-token
AURORA_AGENT_AGENT_NAME=agent-local-01
AURORA_AGENT_TAGS=default,linux
AURORA_AGENT_MAX_CONCURRENCY=1
AURORA_AGENT_POLL_SECONDS=3
